			"name": "6. Admin Dashboard Tasks (With Filters)",
			"item": [
				{
					"name": "Admin Tasks DataTables AJAX",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "X-Requested-With", "value": "XMLHttpRequest", "type": "text" },
							{ "key": "Accept", "value": "application/json", "type": "text" }
						],
						"url": {
							"raw": "{{base_url}}/admin/tasks?draw=1&start=0&length=10&status=NEW&driver_id=141&billing_client=25&from_location=1358&to_location=1048&search_date=tasks.created_at&date_from=2026-05-01&date_to=2026-05-17",
							"host": ["{{base_url}}"],
							"path": ["admin", "tasks"],
							"query": [
								{ "key": "draw", "value": "1", "description": "DataTable draw sequence counter" },
								{ "key": "start", "value": "0", "description": "Starting record index" },
								{ "key": "length", "value": "10", "description": "Records per page" },
								{ "key": "status", "value": "NEW", "description": "Filter by status: NEW, COLLECTED, IN_FREEZER, OUT_FREEZER, CLOSED, NO_SAMPLES" },
								{ "key": "driver_id", "value": "141", "description": "Filter by Driver ID" },
								{ "key": "billing_client", "value": "25", "description": "Filter by Billing Client ID" },
								{ "key": "from_location", "value": "1358", "description": "Filter by Pickup Location ID" },
								{ "key": "to_location", "value": "1048", "description": "Filter by Dropoff Location ID" },
								{ "key": "search_date", "value": "tasks.created_at", "description": "Date column: tasks.created_at, tasks.collection_date, tasks.close_date" },
								{ "key": "date_from", "value": "2026-05-01", "description": "Date from (Y-m-d)" },
								{ "key": "date_to", "value": "2026-05-17", "description": "Date to (Y-m-d)" },
								{ "key": "keyword", "value": "", "description": "Search by Task ID", "disabled": true }
							]
						},
						"description": "Fetch tasks list for the admin dashboard via AJAX, utilizing Yajra DataTables structure and smart caching/date-range filtering."
					}
				}
			]
		},
