	"item": [
		{
			"name": "1. Authentication & Session Management",
			"item": [
				{
					"name": "1.1 Web - Get Login Page (CSRF Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Extract CSRF token from HTML response and store in environment variable",
									"var responseHTML = pm.response.text();",
									"var match = responseHTML.match(/name=\"_token\"\\s+value=\"([^\"]+)\"/);",
									"if (match) {",
									"    pm.environment.set(\"csrf_token\", match[1]);",
									"    console.log(\"CSRF Token extracted: \" + match[1]);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						},
						"description": "Accesses the web login page to retrieve the session cookie and extracts the CSRF token automatically to the environment variable {{csrf_token}}."
					}
				},
				{
					"name": "1.2 Web - Login Submit (Admin/Client Session)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "email", "value": "admin@admin.com", "type": "text" },
								{ "key": "password", "value": "password", "type": "text" },
								{ "key": "_token", "value": "{{csrf_token}}", "type": "text", "description": "Automatically populated CSRF token from the GET request" }
							]
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						},
						"description": "Submits the web login form to authenticate and obtain the session cookie (laravel_session) needed for all /admin routes."
					}
				},
				{
					"name": "1.3 Driver Login (API)",
